# Exemplo de variáveis de ambiente para o projeto
# Renomeie este arquivo para .env e preencha com seus dados

# Usando SQLite Local
DATABASE_URL="file:./marmoraria.db"

# Usando Supabase (PostgreSQL)
# DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Outras configurações
PORT=3000
NODE_ENV=development
